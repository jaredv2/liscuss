# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore editor folders
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
.venv

# Ignore dependencies
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock

# Ignore logs and runtime files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
*.tmp
*.temp

# Ignore build output
dist/
build/
out/

# Ignore environment files
.env
.env.local
.env.*.local

# Ignore Python caches
__pycache__/
*.py[cod]
*$py.class

# Ignore macOS files
.AppleDouble
.LSOverride

# Ignore Windows thumbnail cache files
ehthumbs.db
Desktop.ini

# Ignore generated archives
*.zip
*.tar.gz
*.rar
*.7z
